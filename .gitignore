# Contenido generado en tiempo de ejecucion
/storage/configs/*
/storage/pids/*
/storage/logs/*
/storage/media/*
/storage/backups/*
!/storage/configs/.gitkeep
!/storage/pids/.gitkeep
!/storage/logs/.gitkeep
!/storage/media/.gitkeep
!/storage/backups/.gitkeep

