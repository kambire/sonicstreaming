# Normalizar todo el texto a LF (imprescindible: el codigo corre en Linux).
* text=auto eol=lf

# Scripts que DEBEN ser LF si o si
*.sh    text eol=lf
*.php   text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.tpl   text eol=lf
*.conf  text eol=lf
*.service text eol=lf

# Binarios (no tocar)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp3 binary
*.gz  binary
