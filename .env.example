# Copia este archivo a .env y ajusta los valores.

APP_NAME="SonicStreaming Panel"
APP_ENV=local            # local | production
APP_DEBUG=true
APP_KEY=change-me-please-32-chars-min   # clave para cifrado de contraseñas admin
APP_TIMEZONE=America/Bogota

# Base de datos (XAMPP por defecto: root sin contraseña)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sonicstreaming
DB_USER=root
DB_PASS=

# Shoutcast
# Driver de control de procesos:
#   mock    -> no arranca procesos reales (ideal para desarrollo en Windows/XAMPP)
#   windows -> arranca sc_serv.exe con proc_open (dev en Windows con Shoutcast local)
#   linux   -> systemctl start/stop shoutcast@<id> (produccion en Linux)
SHOUTCAST_DRIVER=mock
SHOUTCAST_BIN="C:/shoutcast/sc_serv.exe"   # ruta al binario (windows/linux)
SHOUTCAST_HOST=127.0.0.1                     # host donde responden las instancias para stats

# AutoDJ (Liquidsoap). En Linux suele bastar con "liquidsoap" (en el PATH).
LIQUIDSOAP_BIN="C:/liquidsoap/liquidsoap.exe"
# Subida de medios AutoDJ: extensiones permitidas
AUTODJ_ALLOWED_EXT="mp3,aac,m4a,ogg,flac,wav"
