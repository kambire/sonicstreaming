{
    "name": "sonicstreaming/panel",
    "description": "Panel de administracion de streaming de audio (Shoutcast + AutoDJ) en PHP y MySQL.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-openssl": "*",
        "ext-curl": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
